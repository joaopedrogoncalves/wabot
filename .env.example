# Secrets (API keys and credentials - not group-specific)
ANTHROPIC_API_KEY=your-anthropic-api-key
GEMINI_API_KEY=your-gemini-api-key
TWITTER_BEARER_TOKEN=your-twitter-bearer-token
GOOGLE_SERVICE_ACCOUNT_EMAIL=bot@project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="your-google-service-account-private-key-with-escaped-newlines"

# Path to group config file (optional, defaults to ./groups.json)
CONFIG_FILE=./groups.json

# Max in-memory chat history per group (optional, defaults to 400)
CHAT_HISTORY_MAX=400

# Web admin interface (optional - web server only starts if ADMIN_TOKEN is set)
ADMIN_TOKEN=your-secret-admin-token
WEB_PORT=3000
