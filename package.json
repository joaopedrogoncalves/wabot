{
  "name": "wabot",
  "version": "1.0.0",
  "description": "WhatsApp group bot for scheduled events, Claude chat replies, Gemini images, passive group profiling, and autonomous cron posts",
  "type": "module",
  "main": "index.js",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "start": "tsx src/index.ts",
    "start:loop": "while true; do tsx src/index.ts; echo \"Process exited ($?), restarting in 5s...\"; sleep 5; done",
    "dev": "tsx watch src/index.ts",
    "typecheck": "tsc --noEmit",
    "audit": "npm audit --omit=dev"
  },
  "overrides": {
    "brace-expansion": "2.1.0",
    "file-type": "21.3.4",
    "minimatch": "9.0.9",
    "music-metadata": "11.12.3",
    "path-to-regexp": "8.4.2",
    "protobufjs": "7.5.5",
    "qs": "6.15.1"
  },
  "keywords": [
    "whatsapp",
    "bot",
    "anthropic",
    "claude",
    "gemini",
    "automation",
    "cron"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.73.0",
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "github:WhiskeySockets/Baileys",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "google-auth-library": "^10.5.0",
    "google-spreadsheet": "^5.0.2",
    "node-cron": "^4.2.1",
    "pino": "^10.3.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
