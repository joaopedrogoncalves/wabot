{
  "name": "wabot",
  "version": "1.0.0",
  "description": "WhatsApp group bot for scheduled events, Claude chat replies, Gemini images, passive group profiling, and autonomous cron posts",
  "type": "module",
  "main": "index.js",
  "scripts": {
    "start": "NODE_OPTIONS='--experimental-global-webcrypto' tsx src/index.ts",
    "start:loop": "while true; do NODE_OPTIONS='--experimental-global-webcrypto' tsx src/index.ts; echo \"Process exited ($?), restarting in 5s...\"; sleep 5; done",
    "dev": "NODE_OPTIONS='--experimental-global-webcrypto' tsx watch src/index.ts"
  },
  "keywords": [
    "whatsapp",
    "bot",
    "anthropic",
    "claude",
    "gemini",
    "automation",
    "cron"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.73.0",
    "@hapi/boom": "^10.0.1",
    "@whiskeysockets/baileys": "github:WhiskeySockets/Baileys",
    "dotenv": "^17.2.4",
    "express": "^5.2.1",
    "google-auth-library": "^10.5.0",
    "google-spreadsheet": "^5.0.2",
    "node-cron": "^4.2.1",
    "pino": "^10.3.0",
    "qrcode-terminal": "^0.12.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.1",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  }
}
